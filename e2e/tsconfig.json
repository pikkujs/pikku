{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "paths": {
      "#pikku/*": ["./.pikku/*"],
      "@pikku/e2e": ["."],
      "@pikku/e2e-functions": ["./packages/functions"]
    }
  },
  "files": [],
  "include": [".pikku/**/*.ts", "src/*.ts", "src/**/*.ts", "bin/**/*.ts"]
}
