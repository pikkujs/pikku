    "test:coverage": "bash run-tests.sh --coverage",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.44"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1"
  },
