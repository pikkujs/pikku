{
  "name": "@pikku/addon-workflow-screenshot",
  "version": "0.12.2",
  "type": "module",
  "imports": {
    "#pikku": "./.pikku/pikku-types.gen.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./.pikku/*": "./.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "files": [
    "dist",
    ".pikku"
  ],
  "scripts": {
    "build": "pikku all && tsc && cp -r .pikku dist/",
    "pikku": "pikku all",
    "pretest": "pikku all",
    "test": "tsc --noEmit"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.3"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.3",
    "@pikku/core": "^0.12.3",
    "typescript": "^5.9"
  },
  "dependencies": {
    "playwright": "^1.52.0",
    "zod": "^4"
  }
}
