{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": false,
    "paths": {
      "@/*": ["./src/*"],
      "@pikku/assistant-ui": ["../assistant-ui/src/index.ts"],
      "@pikku/mantine/core": ["../frontend/mantine/src/core/index.ts"],
      "@pikku/react": ["../frontend/react/src/index.ts"]
    },
    "typeRoots": ["./node_modules/@types", "./types"],
    "target": "ES2017"
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "dist", "backend"]
}
