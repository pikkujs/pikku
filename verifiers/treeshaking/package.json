{
  "name": "@pikku/verifiers-treeshaking",
  "type": "module",
  "private": true,
  "imports": {
    "#pikku": "./.pikku/pikku-types.gen.ts",
    "#pikku/*": "./.pikku/*"
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "ncu": "npx npm-check-updates",
    "ncu:pikku": "npx npm-check-updates -f '/@pikku/.*/'",
    "test": "pikku && tsc && npx tsx test-treeshaking.ts",
    "generate:readme": "npx tsx scripts/generate-readme.ts",
    "prebuild": "npm run generate:readme"
  },
  "dependencies": {
    "@pikku/core": "^0.12.11",
    "@pikku/templates-function-addon": "workspace:*"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.9",
    "@types/node": "^24",
    "typescript": "^5.9"
  }
}
