{
  "name": "@pikku/templates-mcp-server",
  "private": true,
  "version": "0.1.4",
  "description": "Pikku Model Context Protocol (MCP) Server Template",
  "type": "module",
  "scripts": {
    "start": "tsx src/start.ts",
    "start:http": "tsx src/start.ts --http",
    "dev": "tsx --watch src/start.ts",
    "tsc": "tsc",
    "ncu": "npx npm-check-updates",
    "ncu:pikku": "npx npm-check-updates -f '/@pikku/.*/'",
    "test": "bash ../functions/run-tests.sh --mcp --ignore-server-ready-check && bash ../functions/run-tests.sh --server 'yarn start:http' --url http://localhost:3000 --mcp-http",
    "test:mcp": "npx tsx client/mcp.ts",
    "test:mcp:http": "npx tsx client/mcp-http.ts"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.20",
    "@types/node": "^24.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@pikku/auth-js": "^0.12.3",
    "@pikku/core": "^0.12.18",
    "@pikku/modelcontextprotocol": "^0.12.4"
  }
}
