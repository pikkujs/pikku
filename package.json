{
  "name": "@pikku/mono",
  "version": "0.9.0",
  "description": "The pikku monorepo",
  "repository": "git@github.com:pikkujs/pikku.git",
  "author": "yasser.fadl@gmail.com",
  "license": "MIT",
  "private": true,
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/addon/*",
      "packages/frontend/*",
      "packages/services/*",
      "packages/gateways/*",
      "packages/runtimes/*",
      "packages/deploy/*",
      "templates/*",
      "verifiers/*",
      "e2e",
      "e2e/packages/*"
    ]
  },
  "scripts": {
    "postinstall": "husky",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "pre-commit": "yarn test && yarn prettier && yarn lint && yarn typedoc",
    "pre-push": "yarn pre-commit",
    "tsc": "yarn workspaces foreach -A -p run tsc",
    "build:packages": "yarn workspaces foreach -p --topological-dev -A --include 'packages/**' --exclude '@pikku/console' --exclude '@pikku/addon-*' run build",
    "build:addons": "yarn workspaces foreach -p --topological-dev -A --include 'packages/addon/**' run build",
    "build:console": "cd packages/console && yarn generate && yarn build && rm -rf ../cli/console-app && cp -r dist ../cli/console-app",
    "build:templates": "yarn workspaces foreach -p -A --include 'templates/**' run build",
    "build:verifiers": "yarn workspaces foreach -p -A --include 'verifiers/**' run build",
    "build": "yarn build:packages && yarn pikku && yarn build:addons && yarn build:templates",
    "release": "yarn build:packages && yarn pikku && yarn build:addons && yarn build:console && npx changeset publish",
    "ncu": "yarn workspaces foreach -p -A run ncu",
    "ncu:pikku": "yarn workspaces foreach -p -A run ncu -f '/@pikku/.*/'",
    "test:verifiers": "yarn workspaces foreach -p -A --include 'verifiers/**' run test",
    "test:templates": "yarn workspaces foreach -A --include 'templates/**' run test",
    "test:e2e": "yarn workspace @pikku/e2e test",
    "test:e2e:ai": "yarn workspace @pikku/e2e test:ai",
    "test": "yarn workspaces foreach -A --exclude '@pikku/templates-*' --exclude '@pikku/verifiers-*' --exclude '@pikku/addon-console' --exclude '@pikku/console' run test",
    "test:coverage": "yarn workspaces foreach -A run test:coverage",
    "lint": "npx --yes oxlint@latest",
    "prettier": "npx --yes prettier . --write --log-level warn",
    "typedoc": "npx --yes typedoc --tsconfig tsconfig.typedoc.json",
    "changeset": "npx changeset",
    "pikku:functions": "cd templates/functions && yarn pikku",
    "pikku:functions:addon": "cd templates/function-addon && yarn pikku",
    "pikku": "yarn run pikku:functions:addon && yarn run pikku:functions && yarn run pikku:nextjs",
    "pikku:nextjs": "cd templates/nextjs && yarn pikku",
    "benchmark": "tsx benchmarks/bench-fetch.ts",
    "benchmark:all": "tsx benchmarks/run-benchmarks.ts",
    "benchmark:verify": "tsx benchmarks/run-benchmarks.ts --verify",
    "benchmark:express": "tsx benchmarks/bench-express.ts",
    "benchmark:fastify": "tsx benchmarks/bench-fastify.ts",
    "benchmark:uws": "tsx benchmarks/bench-uws.ts",
    "benchmark:baseline:express": "tsx benchmarks/bench-baseline-express.ts",
    "benchmark:baseline:fastify": "tsx benchmarks/bench-baseline-fastify.ts",
    "benchmark:baseline:uws": "tsx benchmarks/bench-baseline-uws.ts",
    "benchmark:flame": "npx 0x -- npx tsx benchmarks/bench-express.ts --flame"
  },
  "packageManager": "yarn@4.10.3",
  "devDependencies": {
    "0x": "^6.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxlint": "^1.60.0",
    "prettier": "3.8.3",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19"
  },
  "dependencies": {
    "@changesets/cli": "^2.31.0",
    "typescript": "~6.0.3"
  },
  "resolutions": {
    "esbuild": "0.27.2"
  },
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.ts": [
      "oxlint",
      "prettier --write"
    ]
  }
}
