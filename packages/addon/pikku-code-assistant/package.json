{
  "name": "@pikku/code-assistant",
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#pikku": {
      "types": "./.pikku/pikku-types.gen.ts",
      "import": "./dist/.pikku/pikku-types.gen.js"
    },
    "#pikku/*": "./.pikku/*"
  },
  "exports": {
    ".": "./dist/.pikku/pikku-bootstrap.gen.js",
    "./.pikku/*": "./dist/.pikku/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pikku all && tsc",
    "pikku": "pikku all",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "@pikku/addon-dynamic-workflows": "workspace:*",
    "@pikku/core": "workspace:*",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@pikku/cli": "workspace:*",
    "typescript": "~5.8.0"
  }
}
