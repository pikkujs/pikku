{
  "$schema": "https://raw.githubusercontent.com/pikkujs/pikku/refs/heads/main/packages/cli/cli.schema.json",
  "srcDirectories": ["./src", "./types"],
  "outDir": "./.pikku",
  "tsconfig": "./tsconfig.json",
  "schema": {
    "supportsImportAttributes": true
  },
  "verboseMeta": true,
  "clientFiles": {
    "fetchFile": ".pikku/pikku-fetch.gen.ts",
    "websocketFile": ".pikku/pikku-websocket.gen.ts",
    "rpcWiringsFile": ".pikku/pikku-rpc.gen.ts",
    "queueWiringsFile": ".pikku/pikku-queue.gen.ts",
    "mcpJsonFile": ".pikku/mcp/mcp.gen.json"
  },
  "scaffold": {
    "workflow": "auth"
  },
  "userFlows": {
    "actors": {
      "customer": {
        "email": "customer@actors.local",
        "jobTitle": "Customer",
        "personality": "Impatient first-time buyer who abandons slow checkouts"
      },
      "ops": {
        "email": "ops@actors.local",
        "jobTitle": "Operations manager"
      }
    }
  }
}
