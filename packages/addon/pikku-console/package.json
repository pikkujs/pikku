{
  "name": "@pikku/addon-console",
  "version": "0.12.8",
  "type": "module",
  "imports": {
    "#pikku": {
      "types": "./.pikku/pikku-types.gen.ts",
      "import": "./dist/.pikku/pikku-types.gen.js"
    }
  },
  "exports": {
    ".": "./dist/.pikku/pikku-bootstrap.gen.js",
    "./.pikku/*": "./dist/.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./dist/.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./dist/.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pikku all && tsc && cp .pikku/rpc/*.d.ts dist/.pikku/rpc/ && cp .pikku/agent/*.d.ts dist/.pikku/agent/ && cp .pikku/workflow/*.d.ts dist/.pikku/workflow/ 2>/dev/null; true",
    "pikku": "pikku all",
    "pretest": "pikku all",
    "test": "tsc --noEmit",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.16"
  },
  "devDependencies": {
    "@pikku/cli": "^0.12.20",
    "@pikku/core": "^0.12.18",
    "oauth2-mock-server": "^7.2.1",
    "typescript": "^5.9"
  },
  "dependencies": {
    "json-schema": "^0.4.0",
    "open": "^10.2.0"
  }
}
