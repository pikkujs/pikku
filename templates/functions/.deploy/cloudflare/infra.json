{
  "projectId": "functions",
  "resources": {
    "d1": [
      {
        "name": "functions-workflow-db",
        "binding": "WORKFLOW_DB"
      }
    ],
    "r2": [],
    "kv": [],
    "queues": [
      {
        "name": "functions-todo-reminders",
        "consumer": "process-reminder"
      },
      {
        "name": "functions-workflow-dispatch",
        "consumer": "workflow-dispatcher"
      }
    ],
    "cronTriggers": [
      {
        "worker": "daily-summary",
        "schedule": "0 9 * * *",
        "name": "dailySummary"
      },
      {
        "worker": "weekly-cleanup",
        "schedule": "0 2 * * 0",
        "name": "weeklyCleanup"
      }
    ],
    "durableObjects": [
      {
        "worker": "channel-todos-live",
        "className": "WebSocketHibernationServer",
        "binding": "WEBSOCKET_HIBERNATION_SERVER"
      },
      {
        "worker": "channel-todo-cli-cli",
        "className": "WebSocketHibernationServer",
        "binding": "WEBSOCKET_HIBERNATION_SERVER"
      }
    ]
  },
  "secrets": [],
  "variables": [],
  "units": {
    "list-todos": {
      "role": "function",
      "bindings": [],
      "routes": [
        {
          "method": "GET",
          "route": "/todos"
        }
      ],
      "handlerTypes": [
        "fetch"
      ]
    },
    "get-todo": {
      "role": "function",
      "bindings": [],
      "routes": [
        {
          "method": "GET",
          "route": "/todos/:id"
        }
