{
  "name": "@pikku/addon-console",
  "version": "0.12.30",
  "type": "module",
  "imports": {
    "#pikku": {
      "types": "./.pikku/pikku-types.gen.ts",
      "import": "./dist/.pikku/pikku-types.gen.js",
      "default": "./dist/.pikku/pikku-types.gen.js"
    }
  },
  "exports": {
    ".": "./dist/.pikku/pikku-bootstrap.gen.js",
    "./.pikku/*": "./dist/.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./dist/.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./dist/.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    },
    "./services": {
      "types": "./dist/src/services/wiring.service.d.ts",
      "import": "./dist/src/services/wiring.service.js",
      "default": "./dist/src/services/wiring.service.js"
    },
    "./channels": {
      "types": "./dist/src/channels.d.ts",
      "import": "./dist/src/channels.js",
      "default": "./dist/src/channels.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pikku all && tsc && (cp .pikku/rpc/*.d.ts dist/.pikku/rpc/ 2>/dev/null || true) && (cp .pikku/agent/*.d.ts dist/.pikku/agent/ 2>/dev/null || true) && (cp .pikku/workflow/*.d.ts dist/.pikku/workflow/ 2>/dev/null || true)",
    "pikku": "pikku all",
    "pretest": "pikku all",
    "test": "tsc --noEmit",
    "test:coverage": "bash run-tests.sh --coverage"
  },
  "peerDependencies": {
    "@pikku/better-auth": "^0.12.19",
    "@pikku/core": "^0.12.68"
  },
  "peerDependenciesMeta": {
    "@pikku/better-auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@pikku/better-auth": "^0.12.19",
    "@pikku/cli": "^0.12.87",
    "@pikku/core": "^0.12.68",
    "oauth2-mock-server": "^7.1.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "json-schema": "^0.4.0",
    "open": "^10.0.0"
  }
}
