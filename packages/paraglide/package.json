{
  "name": "@pikku/paraglide",
  "version": "0.12.2",
  "author": "yasser.fadl@gmail.com",
  "license": "MIT",
  "description": "Paraglide tooling for pikku apps — generates typed enum-lookup maps from `enum__*` message keys.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "bin": {
    "paraglide-enums": "dist/esm/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./vite": {
      "import": "./dist/esm/vite.js",
      "require": "./dist/cjs/vite.js"
    }
  },
  "scripts": {
    "tsc": "tsc",
    "test": "tsx --test src/*.test.ts",
    "build:esm": "tsc -b && echo '{\"type\": \"module\"}' > dist/esm/package.json",
    "build:cjs": "tsc -b tsconfig.cjs.json && echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json",
    "build": "yarn build:esm && yarn build:cjs",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "vite": "^5 || ^6 || ^7"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^7"
  }
}
