{
  "name": "@pikku/modelcontextprotocol",
  "version": "0.12.5",
  "description": "A Pikku MCP server runtime using the official MCP SDK",
  "license": "MIT",
  "author": "yasser.fadl@gmail.com",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "tsc": "tsc",
    "ncu": "npx npm-check-updates",
    "build": "tsc -b",
