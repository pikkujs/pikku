{
  "name": "@pikku/code-assistant",
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#pikku": {
      "types": "./.pikku/pikku-types.gen.ts",
      "import": "./dist/.pikku/pikku-types.gen.js"
    },
    "#pikku/*": "./.pikku/*"
  },
  "exports": {
    ".": "./dist/.pikku/pikku-bootstrap.gen.js",
    "./.pikku/*": "./dist/.pikku/*",
    "./.pikku/pikku-metadata.gen.json": "./.pikku/pikku-metadata.gen.json",
    "./.pikku/rpc/pikku-rpc-wirings-map.internal.gen.js": {
      "types": "./dist/.pikku/rpc/pikku-rpc-wirings-map.internal.gen.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pikku all && tsc && cp .pikku/rpc/*.d.ts dist/.pikku/rpc/ && cp .pikku/agent/*.d.ts dist/.pikku/agent/ && cp .pikku/workflow/*.d.ts dist/.pikku/workflow/ 2>/dev/null; true",
    "pikku": "pikku all",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "@pikku/addon-dynamic-workflows": "workspace:*",
    "@pikku/core": "workspace:*",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@pikku/cli": "workspace:*",
    "typescript": "~5.8.0"
  }
}
