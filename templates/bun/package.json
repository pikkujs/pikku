{
  "name": "@pikku/templates-bun",
  "main": "src/start.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "tsc": "tsc",
    "compile": "bun build --compile src/start.ts --outfile dist/server --minify",
    "ncu": "npx npm-check-updates",
    "ncu:pikku": "npx npm-check-updates -f '/@pikku/.*/'",
    "start": "bun src/start.ts",
    "dev": "bun --watch src/start.ts"
  },
  "dependencies": {
    "@pikku/bun-server": "^0.12.1",
    "@pikku/core": "^0.12.43",
    "@pikku/schedule": "^0.12.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
