{
  "name": "@pikku/cli",
  "version": "0.12.87",
  "author": "yasser.fadl@gmail.com",
  "license": "BUSL-1.1",
  "imports": {
    "#pikku": "./dist/.pikku/pikku-types.gen.js",
    "#pikku/*": "./dist/.pikku/*"
  },
  "bin": {
    "pikku": "dist/bin/pikku.js"
  },
  "type": "module",
  "main": "dist/bin/pikku.js",
  "module": "dist/bin/pikku.js",
  "scripts": {
    "tsc": "tsc",
    "schema": "ts-json-schema-generator -o cli.schema.json --path 'src/utils/pikku-cli-config.ts' --type 'PikkuCLIConfig'",
    "build": "./build.sh",
    "ncu": "npx npm-check-updates -x '/.*glob.*/'",
    "release": "yarn build && npm test",
    "test": "bash run-tests.sh",
    "test:watch": "bash run-tests.sh --watch",
    "test:coverage": "bash run-tests.sh --coverage",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.1",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@openapi-contrib/json-schema-to-openapi-schema": "^4.3.1",
    "@pikku/better-auth": "^0.12.19",
    "@pikku/bun-server": "^0.12.4",
    "@pikku/deploy-cloudflare": "^0.12.8",
    "@pikku/fetch": "^0.12.8",
    "@pikku/inspector": "^0.12.46",
    "@pikku/kysely": "^0.13.2",
    "@pikku/kysely-node-sqlite": "^0.12.3",
    "@pikku/n8n-import": "^0.0.3",
    "@pikku/node-http-server": "^0.12.6",
    "@pikku/openapi-parser": "^0.12.16",
    "@pikku/schedule": "^0.12.4",
    "@pikku/ws": "^0.12.4",
    "@types/cookie": "^1.0.0",
    "@types/json-schema": "^7.0.15",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "esbuild": "~0.27.0",
    "istanbul-lib-instrument": "^6.0.3",
    "open": "^10.2.0",
    "openapi-types": "^12.1.3",
    "path-to-regexp": "^8.3.0",
    "pg": "^8.13.0",
    "tinyglobby": "^0.2.12",
    "ts-json-schema-generator": "2.9.1-next.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "ws": "^8.18.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod-to-ts": "^2.1.0"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.68"
  },
  "devDependencies": {
    "@pikku/core": "^0.12.68",
    "@types/istanbul-lib-instrument": "^1.7.7",
    "@types/node": "^24.11.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8"
  },
  "files": [
    "dist",
    "console-app",
    "skills",
    "cli.schema.json"
  ],
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": "./dist/bin/pikku.js"
  }
}
