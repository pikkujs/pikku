    "./d1": "./dist/cloudflare-d1-services.js",
    "./deployment": "./dist/cloudflare-deployment-service.js",
    "./websocket": "./dist/cloudflare-hibernation-websocket-server.js",
    "./eventhub": "./dist/cloudflare-eventhub-service.js",
    "./workflow-do": "./dist/workflow-do/index.js"
  },
  "dependencies": {
    "kysely-d1": "^0.4.0"
  },
  "peerDependencies": {
    "@pikku/core": "^0.12.44",
