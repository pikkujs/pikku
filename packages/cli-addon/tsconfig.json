{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "module": "Node18",
    "outDir": "dist",
    "target": "esnext",
    "declaration": true,
    "resolveJsonModule": true,
    "composite": true
  },
  "include": [
    "src/**/*.ts",
    ".pikku/**/*.ts",
    ".pikku/**/*.json",
    "types/*.ts",
    "types/*.d.ts"
  ],
  "exclude": ["**/*.test.ts", "node_modules"],
  "references": [
    {
      "path": "../core/tsconfig.json"
    },
    {
      "path": "../inspector/tsconfig.json"
    },
    {
      "path": "../openapi-to-zod-schema/tsconfig.json"
    }
  ]
}
